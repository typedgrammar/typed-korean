{
  "name": "@typedgrammar/typed-korean-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/gen-reverse-index.mjs && vite",
    "build": "node scripts/gen-reverse-index.mjs && tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist-server && node scripts/prerender.mjs",
    "gen:reverse-index": "node scripts/gen-reverse-index.mjs",
    "annotate": "bun scripts/annotate.ts",
    "preview": "vite preview",
    "typecheck": "node scripts/gen-reverse-index.mjs && tsc --noEmit",
    "verify:snippets": "node scripts/verify-snippets.mjs",
    "verify:vocab": "node scripts/verify-vocab.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "monaco-editor": "^0.52.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4",
    "vite": "^8.0.16"
  }
}
